## deployment/.env.template
## Copy to deployment/.env and fill in your values.
## Never commit the .env file.

# ─── Required ──────────────────────────────────────────────────────────────────
WEB_APP_NAME_PREFIX=""        # ≤21 chars, e.g. "mycompany"
LOCATION=""                   # Azure region, e.g. "East US"
PUBLISHER_ADMIN_USERS=""      # Comma-separated emails granted admin access, e.g. "you@example.com"

# ─── Optional (defaults derived from prefix) ───────────────────────────────────
RESOURCE_GROUP=""             # Defaults to WEB_APP_NAME_PREFIX
AZURE_SUBSCRIPTION_ID=""      # Leave blank to use current az account
DB_SERVER_NAME=""             # Defaults to ${prefix}-db
DB_NAME=""                    # Defaults to ${prefix}AMPSaaSDB
KEY_VAULT=""                  # Defaults to ${prefix}-kv
ACR_NAME=""                   # Defaults to ${prefix without dashes}acr

# ─── Azure AD App Registrations (auto-created if blank) ────────────────────────
TENANT_ID=""                  # Your Azure AD tenant ID; defaults to current account
AD_APPLICATION_ID=""          # Fulfillment API app reg client ID
AD_APPLICATION_SECRET=""      # Fulfillment API app reg secret (required if ID provided)
AD_APPLICATION_ID_ADMIN=""    # Admin Portal SSO app reg client ID

# ─── CI/CD pipeline build args ─────────────────────────────────────────────────
# (These override the auto-derived URLs; normally left blank in .env
#  and set as pipeline variables in Azure DevOps instead.)
VITE_ADMIN_API_URL=""         # e.g. https://mycompany-admin.azurewebsites.net
VITE_CUSTOMER_API_URL=""      # e.g. https://mycompany-portal.azurewebsites.net
