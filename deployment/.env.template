## deployment/.env.template
## Copy to deployment/.env and fill in your values.  Never commit .env.
##
## Usage: ./deployment/deploy.sh --prefix myco --location "East US" \
##          --publisher-admin-users "admin@myco.com"
## Or:    cp deployment/.env.template deployment/.env && edit it, then ./deployment/deploy.sh

# ─── Required ──────────────────────────────────────────────────────────────────
WEB_APP_NAME_PREFIX=""        # ≤ 21 chars, e.g. "mycompany"
LOCATION=""                   # Azure region, e.g. "East US"
PUBLISHER_ADMIN_USERS=""      # Comma-separated emails, e.g. "admin@myco.com,other@myco.com"

# ─── Optional — defaults derived from prefix ───────────────────────────────────
RESOURCE_GROUP=""             # default: same as WEB_APP_NAME_PREFIX
AZURE_SUBSCRIPTION_ID=""      # default: current az account
TENANT_ID=""                  # default: current az account tenant

# Database
DB_SERVER_NAME=""             # default: ${prefix}-db
DB_NAME=""                    # default: ${prefix}AMPSaaSDB

# Key Vault
KEY_VAULT=""                  # default: ${prefix}-kv

# Container Registry
ACR_NAME=""                   # default: ${prefix without dashes}acr
ACR_SUBSCRIPTION=""           # set if ACR is in a different subscription

# ─── Azure AD App Registrations (auto-created if blank) ────────────────────────
AD_APPLICATION_ID=""          # Fulfillment API app reg client ID
AD_APPLICATION_SECRET=""      # Fulfillment API secret (required if ID is provided)
AD_APPLICATION_ID_ADMIN=""    # Admin Portal SSO app reg client ID

# ─── Docker Hub (enables ACR pull-through cache for base images) ───────────────
# With these set, base images (rust, node, debian) are cached in your ACR.
# This avoids DockerHub rate limits and speeds up builds (~30% faster).
# Credentials are stored in Key Vault — never in app settings.
DOCKERHUB_USERNAME=""         # Docker Hub username
DOCKERHUB_TOKEN=""            # Docker Hub access token (NOT your password)
                              # Create at https://hub.docker.com/settings/security

# ─── Frontend URLs (baked into the React bundle) ───────────────────────────────
# Normally derived from the web app names above. Override only if using custom domains.
VITE_ADMIN_API_URL=""         # e.g. https://mycompany-admin.azurewebsites.net
VITE_CUSTOMER_API_URL=""      # e.g. https://mycompany-portal.azurewebsites.net
